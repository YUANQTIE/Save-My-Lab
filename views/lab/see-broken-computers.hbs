<html lang="en" data-theme="light"></html>
<head>
    <link rel="stylesheet" href="/css/default/homepage2.css">
    <link rel="stylesheet" href="/css/lab/see-reservations.css">
</head>


<div class="page p-6 bg-white">
    <p class="text-xl font-bold text-slate-800 mb-6">Maintained Computers</p>

    <div class="bg-slate-50 p-4 rounded-xl mb-6 border border-slate-100 shadow-sm">
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3 items-center">
            <select id="buildingInput" class="select select-bordered select-xs w-full column-filter">
                <option value="">Input Building</option>
                <option value="Gokongwei Building">Gokongwei Building</option>
                <option value="St. La Salle Hall">St. La Salle Hall</option>
                <option value="Don Enrique T. Yuchengco Hall">Don Enrique T. Yuchengco Hall</option>
                <option value="Br. Andrew Gonzales Hall">Br. Andrew Gonzales Hall</option>
            </select>

            <select id="roomInput" class="select select-bordered select-xs w-full column-filter">
                <option value="">Input Room</option>
            </select>

            <input id="reasonInput" type="text" placeholder="Search by reason" class="input input-bordered input-xs w-full column-filter">

            <input id="maintenanceDateInput" type="date" class="input input-bordered input-xs w-full column-filter">

            <div class="flex items-center gap-1">
                <span class="text-[10px] font-bold uppercase text-slate-400">Start</span>
                <div class="flex items-center gap-1 flex-1">
                    <select id="startHr" class="select select-bordered select-xs flex-1 time-filter">
                        <option value="">Hr</option>
                        <option value="07">7</option>
                        <option value="08">8</option>
                        <option value="09">9</option>
                        <option value="10">10</option>
                        <option value="11">11</option>
                        <option value="12">12</option>
                        <option value="13">1</option>
                        <option value="14">2</option>
                        <option value="15">3</option>
                        <option value="16">4</option>
                        <option value="17">5</option>
                        <option value="18">6</option>
                        <option value="19">7</option>
                        <option value="20">8</option>
                    </select>
                    <span class="text-slate-400 font-bold">:</span>
                    <select id="startMin" class="select select-bordered select-xs flex-1 time-filter">
                        <option value="">Min</option>
                        <option value="00">00</option>
                        <option value="30">30</option>
                    </select>
                </div>
            </div>

            <button id="resetBtn" class="btn btn-ghost btn-xs text-slate-500 hover:bg-slate-200">Reset</button>
        </div>
    </div>

    <div class="overflow-x-auto w-full px-4">
        <table id="reservationTable" class="w-full bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <thead class="bg-slate-50 border-b border-slate-100 text-center">
                <tr class="text-center">
                    <th class="py-3 text-slate-800 px-4 text-sm text-center">Building</th>
                    <th class="py-3 text-slate-800 px-4 text-sm text-center">Room</th>
                    <th class="py-3 text-slate-800 px-4 text-sm text-center">Reason</th>
                    <th class="py-3 text-slate-800 px-4 text-sm text-center">Unavailable Since</th>
                    <th class="py-3 text-slate-800 px-4 text-sm text-center">Actions</th>
                </tr>
            </thead>

            <tbody id="tbody" class="text-slate-700">

            </tbody>
        </table>
    </div>
</div>

{{!-- Modal for View Seats --}}
<div id="view_modal" class="fixed inset-0 z-[9999] flex items-center justify-center p-4 hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm modal-backdrop"></div>

    <div class="relative z-10 w-full max-w-sm bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">
        <div class="bg-[#1e3a2a] px-6 py-4 flex justify-between items-center">
            <h3 class="font-bold text-white tracking-wide">Seats to be maintained</h3>
            <button type="button" id="hide_view_modal"
                class="text-white/70 hover:text-white transition-transform active:scale-90">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="p-8">
            <div id="view_modal_body" class="flex flex-wrap gap-3 justify-center">
            </div>

            <div class="mt-8 flex justify-center">
                <button id="confirm_okay" type="button"
                    class="w-full bg-[#1e3a2a] hover:bg-[#2d523d] text-white font-bold py-3 px-6 rounded-xl transition-all shadow-md active:translate-y-0.5">
                    Got it
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="/scripts/lab/see-broken-computers.js"></script>