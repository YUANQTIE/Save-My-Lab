<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
  $(document).ready(function () {
    console.log("Navbar Script running");
    const url = new URLSearchParams(window.location.search);
    const adminId = url.get('id');
    $("#reserve").on("click", async function (e) {
      e.preventDefault();
      try {
        window.location.href = `/admin/edit-computer-status?id=${adminId}`
      } catch (err) {
        console.error("Login Error:", err);
        alert("An error occurred. Check the F12 console.");
      }
    });

    $("#profile").on("click", async function (e) {
      e.preventDefault();
      try {
        window.location.href = `/admin/landing?id=${adminId}`
      } catch (err) {
        console.error("Login Error:", err);
        alert("An error occurred. Check the F12 console.");
      }
    });

    $("#home").on("click", async function (e) {
      e.preventDefault();
      try {
        window.location.href = `/admin/add-reservation?id=${adminId}`
      } catch (err) {
        console.error("Login Error:", err);
        alert("An error occurred. Check the F12 console.");
      }
    });
  })
</script>