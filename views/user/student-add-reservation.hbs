        <div class="controls">
          <!-- Venue Input -->
          <div id="venue" class="input-box">
            <select id="venueInput" required>
              <option value="" disabled selected>Input Venue...</option>
              <option value="Gokongwei Building">Gokongwei Building</option>
              <option value="Br. Andrew Gonzales Hall">Br. Andrew Gonzales Hall</option>
              <option value="St. La Salle Hall">St. La Salle Hall</option>
              <option value="Don Enrique T. Yuchengco Hall">Don Enrique T. Yuchengco Hall</option>
            </select>
          </div>

          <!-- Room Input -->
          <div id="room" class="input-box hidden" id="roomBox">
            <select id="roomInput">
              <option value="" disabled selected>Input Room...</option>
            </select>
          </div>

          <!-- Date Input -->
          <div id="date" class="input-box hidden" id="dateBox">
            <input id="dateInput" type="date" min="" max="">
          </div>

          <!-- Time Input -->
          <div id="time" class="time-block hidden" id="timeBox">
            <div class="time-row">
              <label class="time-label">Time Start</label>
              <select id="startHourInput" class="time-input">
                <option value="" disabled selected>--</option>
                <option value="07">07</option>
                <option value="08">08</option>
                <option value="09">09</option>
                <option value="10">10</option>
                <option value="11">11</option>
