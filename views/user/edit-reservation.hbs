          <option value="Br. Andrew Gonzales Hall">Br. Andrew Gonzales Hall</option>
          <option value="St. La Salle Hall">St. La Salle Hall</option>
          <option value="Don Enrique T. Yuchengco Hall">Don Enrique T. Yuchengco Hall</option>
        </select>
      </div>

      <!-- Room Input -->
      <div id="room" class="input-box" id="roomBox">
        <select id="roomInput">
          <option value="" disabled selected>Input Room...</option>
        </select>
      </div>

      <!-- Date Input -->
      <div id="date" class="input-box" id="dateBox">
        <input id="dateInput" type="date" min="" max="">
      </div>

      <!-- Time Input -->
      <div id="time" class="time-block" id="timeBox">
        <div class="time-row">
          <label class="time-label">Time Start</label>
          <select id="startHourInput" class="time-input">
            <option value="" disabled selected>--</option>
          </select>
          <span class="time-colon">:</span>
          <select id="startMinuteInput" class="time-input">
            <option value="" disabled selected>--</option>
          </select>
        </div>

        <div class="time-row">
          <label class="time-label">Time End</label>
          <select id="endHourInput" class="time-input">
            <option value="" disabled selected>--</option>
          </select>
          <span class="time-colon">:</span>
          <select id="endMinuteInput" class="time-input">
            <option value="" disabled selected>--</option>
          </select>
        </div>
      </div>

      <!-- Confirm Button -->
      <button id="confirmBtn" class="confirm-button" disabled>CONFIRM</button>
    </div>
