  {{!-- Confirm Modal --}}
  <div id="confirmModal" class="hidden fixed inset-0 z-[9999] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm modal-backdrop"></div>

    <div
