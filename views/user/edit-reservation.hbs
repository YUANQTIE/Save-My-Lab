      <div class="bg-[#1e3a2a] px-6 py-5 flex justify-between items-center">
        <h3 class="font-bold text-white text-lg tracking-tight">Confirm Reservation</h3>
        <button type="button" class="close-confirm text-white/70 hover:text-white transition-transform active:scale-90">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="p-6">
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="space-y-1">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Location</p>
            <p class="text-sm font-semibold text-slate-800" id="resVenue">Gokongwei Building</p>
            <p class="text-xs text-slate-500" id="resRoom">Room G201</p>
          </div>
          <div class="space-y-1 border-l pl-4 border-slate-100">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Schedule</p>
            <p class="text-sm font-semibold text-slate-800" id="resDate">March 25, 2026</p>
            <p class="text-xs text-slate-500" id="resTime">14:00 - 15:00</p>
          </div>
        </div>

        <div class="bg-slate-50 rounded-xl p-4 border border-slate-100 mb-6">
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3">Selected Computers</p>
          <div id="resSeats" class="flex flex-wrap gap-2">
            <span
              class="px-2 py-1 bg-white border border-slate-200 rounded text-xs font-bold text-[#1e3a2a]">G201-31</span>
          </div>
        </div>

        <div class="flex items-center justify-between pt-4 border-t border-slate-100">
          <label class="flex items-center gap-2 leading-none ...">
            <div class="relative flex items-center">
              <input id="anon" type="checkbox" name="anonymous"
                class="peer w-5 h-5 rounded border-slate-300 text-[#1e3a2a] focus:ring-[#1e3a2a] cursor-pointer">
            </div>
            <span class="text-sm font-medium text-slate-600 group-hover:text-slate-900 transition-colors">Reserve
              Anonymously</span>
          </label>

          <button id="confirmOkay" type="button"
            class="flex items-center bg-[#1e3a2a] hover:bg-[#2d523d] text-white font-bold py-2.5 px-8 rounded-xl transition-all shadow-md hover:shadow-lg active:scale-95">
            <svg aria-hidden="true" id="loading" class="hidden w-5 h-5 mr-2 animate-spin text-white/20 fill-white" viewBox="0 0 100 101"
              fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z"
                fill="currentColor" />
              <path
                d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z"
